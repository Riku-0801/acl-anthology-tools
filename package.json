{
  "name": "acl-anthology-tools",
  "version": "1.0.0",
  "description": "Chrome Extension that enhances ACL Anthology with BibTeX copy, abstract preview, bookmarks, and more",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "happy-dom": "^12.10.3",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vite-plugin-web-extension": "^4.1.1",
    "vitest": "^1.2.2"
  }
}
